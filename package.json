{
  "name": "request-kit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit && tsc -p tools --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "fixtures": "bun run tools/fixture-server.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "pinia": "^4",
    "vue": "^3.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@types/bun": "^1.3.14",
    "@vitejs/plugin-vue": "^6",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.10.0",
    "happy-dom": "^20.11.1",
    "prettier": "^3.9.6",
    "typescript": "^5",
    "typescript-eslint": "^8.65.0",
    "vite": "^8",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.8"
  }
}
